{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "strict": true,
        "noEmit": true,
        "isolatedModules": true,
        "types": ["node"]
    },
    "include": ["src/server/**/*", "src/shared/**/*"]
}
